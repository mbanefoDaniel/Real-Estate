# Core
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/real_estate_db?schema=public"
AUTH_JWT_SECRET="replace_with_long_random_secret"
APP_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Cloudinary Uploads
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Turnstile CAPTCHA
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your_turnstile_site_key"
TURNSTILE_SECRET_KEY="your_turnstile_secret_key"

# Featured Listing Pricing (NGN)
FEATURED_LISTING_PRICE_NGN="5000"
FEATURED_LISTING_PLUS_PRICE_NGN="12000"
FEATURED_LISTING_PREMIUM_PRICE_NGN="25000"
MONTHLY_SUBSCRIPTION_PRICE_NGN="15000"

# Paystack
PAYSTACK_SECRET_KEY="your_paystack_secret"

# Saved Search Alerts Cron
CRON_ALERTS_SECRET="set_a_strong_shared_secret"

# SMTP (emails: reset password, notifications, alerts)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_SECURE="false"
SMTP_FROM_EMAIL="no-reply@naijapropertyhub.ng"
SMTP_FROM_NAME="NaijaProperty Hub"

# Optional distributed rate-limit storage (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://<instance>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"
