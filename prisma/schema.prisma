
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PropertyKind {
  LAND
  HOUSE
  APARTMENT
}

enum ListingTerm {
  SALE
  LEASE
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  FAILED
}

enum AuditEntityType {
  PROPERTY
  USER
  LEAD
  SYSTEM
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  passwordHash    String
  emailVerified   Boolean   @default(false)
  role            UserRole  @default(USER)
  profileImageUrl String?
  kycStatus       KycStatus @default(NOT_SUBMITTED)
  kycDocumentUrl  String?
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resetTokens     PasswordResetToken[]
  savedSearches   SavedSearch[]
  subscriptions   Subscription[]
  otps            EmailOtp[]

  @@index([email])
}

model EmailOtp {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  purpose   String    // "email-verify" or "password-change"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id         String             @id @default(cuid())
  userId     String
  plan       String             @default("MONTHLY")
  provider   PaymentProvider    @default(PAYSTACK)
  status     SubscriptionStatus @default(PENDING)
  reference  String             @unique
  amount     Int
  paymentUrl String?
  startsAt   DateTime?
  expiresAt  DateTime?
  paidAt     DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String
  city        String
  address     String
  ownerEmail  String   @default("unknown@christoland.ng")
  kind        PropertyKind @default(HOUSE)
  listingTerm ListingTerm  @default(SALE)
  status      ListingStatus @default(PENDING)
  price       Int
  bedrooms    Int
  bathrooms   Float
  areaSqft    Int
  imageUrl    String?
  moderationReason String?
  moderatedByEmail String?
  moderatedAt DateTime?
  isArchived  Boolean  @default(false)
  archivedAt  DateTime?
  archivedByEmail String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      PropertyImage[]
  leads       Lead[]
  featuredPayments FeaturedPayment[]

  @@index([city])
  @@index([price])
  @@index([ownerEmail])
  @@index([isArchived])
}

model SavedSearch {
  id           String   @id @default(cuid())
  userId       String
  label        String
  location     String?
  category     PropertyKind?
  listingTerm  ListingTerm?
  beds         Int?
  plotSize     Int?
  minPrice     Int?
  maxPrice     Int?
  alertEnabled Boolean  @default(true)
  alertFrequency AlertFrequency @default(DAILY)
  lastAlertSentAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([alertEnabled])
}

model AdminAuditLog {
  id         String          @id @default(cuid())
  adminEmail String
  action     String
  entityType AuditEntityType
  entityId   String
  metadata   Json?
  createdAt  DateTime        @default(now())

  @@index([adminEmail])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model FeaturedPayment {
  id          String          @id @default(cuid())
  propertyId  String
  ownerEmail  String
  provider    PaymentProvider @default(PAYSTACK)
  status      PaymentStatus   @default(PENDING)
  reference   String          @unique
  amount      Int
  currency    String          @default("NGN")
  paymentUrl  String?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([ownerEmail])
  @@index([status])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  imageUrl   String
  sortOrder  Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Lead {
  id         String     @id @default(cuid())
  propertyId String
  name       String
  email      String
  phone      String?
  whatsapp   String?
  message    String
  status     LeadStatus @default(NEW)
  createdAt  DateTime   @default(now())
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([status])
}
